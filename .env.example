# Copy to .env for local development (never commit .env)
NF_APP_ENV=local
NF_APP_NAME=NativeForge

# PostgreSQL (use for local dev and Alembic). Tests override this to in-memory SQLite.
DATABASE_URL=postgresql+psycopg://nativeforge:nativeforge@localhost:5432/nativeforge

# NF-001 demo isolation: comma-separated org UUIDs treated as demo orgs (see docs/demo-isolation.md).
# NF_DEMO_ORG_IDS=

# Dev-only: accept X-NF-Org-Id for /v1/isolation/* smoke routes. Set false to simulate prod (503).
# NF_DEV_ORG_HEADERS=true
